# ─── 必填 ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/girlfriend
JWT_SECRET=your-secret-key-change-me

# ─── AI 提供商（至少配置一个）─────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=openai
# LLM 软额度提醒：0 表示不启用；只做诊断提醒，不会自动阻断回复
LLM_DAILY_SOFT_TOKEN_LIMIT=0
LLM_MONTHLY_SOFT_TOKEN_LIMIT=0
LLM_BUDGET_WARNING_RATIO=0.8

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：deepseek-v4-flash 或 deepseek-v4-pro；Pro 成本更高但推理更强
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING=enabled
# DeepSeek 文档中的 XHigh 兼容档会映射为 max
DEEPSEEK_REASONING_EFFORT=max
# 动态 Flash/Pro 路由用的两个模型（轻任务走 Flash 省成本、重任务走 Pro，见 server/llm/index.ts）
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro

# Kimi (Moonshot)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_BASE_URL=https://api.anthropic.com

# Ollama (本地)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Dify
DIFY_API_KEY=
DIFY_URL=

# 讯飞星火
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=
XUNFEI_MODEL_VERSION=v3.5

# 通义千问
TONGYI_API_KEY=
TONGYI_URL=
TONGYI_MODEL=qwen-turbo

# 专用视觉模型（可选，用于 QQ 图片/表情包理解；主聊天模型仍可用 DeepSeek）
# 默认兼容阿里云百炼 / DashScope 的 OpenAI-compatible 接口
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3-vl-flash
VISION_MAX_INLINE_BYTES=7340032

# 豆包
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=

# 302AI
_302AI_API_KEY=

# ─── QQ / OneBot（可选，推荐配合 NapCatQQ）──────────────────────────────────
QQ_ENABLED=false
QQ_ONEBOT_BASE_URL=http://127.0.0.1:3001
QQ_ONEBOT_ACCESS_TOKEN=
QQ_ONEBOT_WEBHOOK_SECRET=
# 可选：NapCat 快速登录目标 QQ 号；为空时启动脚本会尝试从 onebot11_*.json 推断。
QQ_QUICK_LOGIN_UIN=
QQ_ALLOW_GROUPS=false
QQ_AUTO_BIND_SINGLE_READY_PERSONA=true

# QQ 语音回复 / TTS
# 默认 Windows 使用本机 SAPI；配置为 voxcpm 后会调用本机 VoxCPM 服务
QQ_VOICE_REPLY_ENABLED=true
QQ_VOICE_REPLY_MODE=smart
QQ_VOICE_REPLY_PROBABILITY=0.25
QQ_VOICE_REPLY_ONLY_WHEN_USER_SENT_VOICE=false
QQ_VOICE_REPLY_MAX_TEXT_LENGTH=45
QQ_VOICE_REPLY_COOLDOWN_SECONDS=90
QQ_VOICE_REPLY_ALLOW_GROUPS=false
# smart 模式会让 LLM 判断短回复是否适合自然语音；为空则使用默认 LLM
QQ_VOICE_REPLY_SMART_PROVIDER=
QQ_VOICE_REPLY_SMART_MIN_CONFIDENCE=0.68
QQ_TTS_PROVIDER=windows-sapi
# 设置为 none 时，VoxCPM/MiniMax 失败会退回文字，不会改用系统 TTS 音色。
QQ_TTS_FALLBACK_PROVIDER=none
QQ_TTS_VOICE=zh-CN-YunxiNeural

# QQ 表情包回复
QQ_STICKER_REPLY_ENABLED=true
QQ_STICKER_REPLY_PROBABILITY=0.18
QQ_STICKER_REPLY_MAX_REPLY_LENGTH=90
QQ_STICKER_REPLY_COOLDOWN_SECONDS=90
QQ_STICKER_REPLY_ALLOW_GROUPS=false
QQ_STICKER_REPLY_ALLOW_AFTER_USER_STICKER=true
QQ_STICKER_REPLY_ALLOW_AFTER_USER_JOKE=true
QQ_STICKER_REPLY_ALLOW_AFTER_USER_TEASE=true
QQ_STICKER_REPLY_AVOID_REPEAT_RECENT_COUNT=3
QQ_STICKER_BASE_DIR=assets/stickers/persona

# VoxCPM 本地 TTS 服务（可选）
VOXCPM_SERVICE_URL=http://127.0.0.1:8818
VOXCPM_CONTROL=年轻男性，声音温和低沉，克制自然，语速中等偏慢，句间有自然停顿，像近距离日常聊天，不要朗读腔
VOXCPM_CLONE_MODE=controllable
VOXCPM_REFERENCE_AUDIO_PATH=
VOXCPM_PROMPT_TEXT=
# VoxCPM 多 voice profile：未配置某个情绪参考音频时，会复用 calm/default 参考音频并使用该 profile 的 control。
VOXCPM_VOICE_PROFILE_DEFAULT=calm
VOXCPM_PROFILE_CALM_REFERENCE_AUDIO_PATH=
VOXCPM_PROFILE_CALM_PROMPT_TEXT=
VOXCPM_PROFILE_CALM_CONTROL=
VOXCPM_PROFILE_COMFORT_REFERENCE_AUDIO_PATH=
VOXCPM_PROFILE_COMFORT_PROMPT_TEXT=
VOXCPM_PROFILE_COMFORT_CONTROL=
VOXCPM_PROFILE_TEASE_REFERENCE_AUDIO_PATH=
VOXCPM_PROFILE_TEASE_PROMPT_TEXT=
VOXCPM_PROFILE_TEASE_CONTROL=
VOXCPM_PROFILE_ANGRY_SOFT_REFERENCE_AUDIO_PATH=
VOXCPM_PROFILE_ANGRY_SOFT_PROMPT_TEXT=
VOXCPM_PROFILE_ANGRY_SOFT_CONTROL=
VOXCPM_PROFILE_SAD_LOW_REFERENCE_AUDIO_PATH=
VOXCPM_PROFILE_SAD_LOW_PROMPT_TEXT=
VOXCPM_PROFILE_SAD_LOW_CONTROL=
VOXCPM_CFG_VALUE=2.0
# 实测 20 步在本机易超时；10 步稳定（与 server 端默认一致）。需要更高音质再上调。
VOXCPM_INFERENCE_STEPS=10
VOXCPM_NORMALIZE=false
VOXCPM_DENOISE=false
VOXCPM_TIMEOUT_MS=120000
# VoxCPM 语音表演稿润色：off | local | llm
# local 只用本地规则加停顿和控制词；llm 会在 TTS 前调用默认 LLM 生成更有情绪起伏的语音稿。
VOXCPM_SPEECH_ENRICHMENT=local
VOXCPM_SPEECH_ENRICHMENT_PROVIDER=

# ─── 拟真增量开关（高风险项，默认关，验证后再开）──────────────────────────────
# 回应延迟：开启后人物在忙碌/克制时段会隔几秒~十几秒才回，更像真人「在忙、晚点看到」。
PERSONA_REPLY_LATENCY_ENABLED=false
# 主动多模态：开启后主动/氛围消息会按低概率发语音条或附表情，而非永远纯文本。
PROACTIVE_MULTIMODAL_ENABLED=false

# ─── 人物拍照（经 chatgpt-project-prompt-pusher 推送网页版 ChatGPT，默认关）─────
# 开启后有两条触发：
#  ① 主路径：人物在对话里自然想拍时会自己输出拍照标记，系统异步生成并以「预告→交付」两步发出
#     （带人自拍 / 在家环境 / 外面场景三态，受冷却与作息门控，深夜等静默时段不主动拍）。
#     注意：人物可能在未被明确索要时也自发拍照，开启前请评估隐私与行为范围。
#  ② 兜底：用户明确说「发张自拍 / 拍张照 / 拍家里 [情境]」时必发（破冷却）。
# 依赖本机的 chatgpt-project-prompt-pusher（--generate 入口）+ 已登录的 Chrome profile。
PERSONA_SELFIE_ENABLED=false
# pusher 的 .csproj 路径（dotnet run --project 用）
PERSONA_SELFIE_PUSHER_PROJECT=
# pusher 的 config（含 targetUrl/downloadDir/profile 等），经 CHATGPT_PROMPT_PUSHER_CONFIG 传入
PERSONA_SELFIE_PUSHER_CONFIG=
# 人物基准脸图片（作为参考图附件）
PERSONA_SELFIE_BASE_FACE_PATH=
# 「家/环境」参考图：拍家里/窗外等环境照时的锚定参考图（不配则环境照不可用，只发自拍）
PERSONA_SELFIE_HOME_REF_PATH=
# 「家」区域参考图目录：放 bedroom/kitchen/livingroom/study/bathroom/entry/balcony.png，按场景自动选对应房间（优先于上面的单图）
PERSONA_SELFIE_HOME_DIR=
# 合拍用的「伴侣脸」参考图（用户自己的清晰正脸）：说「合拍/合照/一起拍」时附人物脸+这张，生成两人合照；不配则合拍退回单人自拍
PERSONA_SELFIE_PARTNER_FACE_PATH=
# 专门用于生成该人物自拍的 ChatGPT 会话 URL（首条已喂基准脸+设定）
PERSONA_SELFIE_TARGET_URL=
# 登录 Chrome profile 的目录名片段（生成前清掉占用它的残留 Chrome）
PERSONA_SELFIE_PROFILE_HINT=google-ai-persistent-profile
# 单张生成总超时（毫秒）
PERSONA_SELFIE_TIMEOUT_MS=600000
# dotnet 可执行路径（默认走 PATH 里的 dotnet）
PERSONA_SELFIE_DOTNET_PATH=dotnet

# ─── 其他 ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
PYTHON_PATH=python3
SKILL_ENGINE_DIR=./skill-engine
PORT=3000
