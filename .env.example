# ─── 必填 ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/girlfriend
JWT_SECRET=your-secret-key-change-me

# ─── AI 提供商（至少配置一个）─────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Kimi (Moonshot)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_BASE_URL=https://api.anthropic.com

# Ollama (本地)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Dify
DIFY_API_KEY=
DIFY_URL=

# 讯飞星火
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=
XUNFEI_MODEL_VERSION=v3.5

# 通义千问
TONGYI_API_KEY=
TONGYI_URL=
TONGYI_MODEL=qwen-turbo

# 专用视觉模型（可选，用于微信图片/表情包理解；主聊天模型仍可用 DeepSeek）
# 默认兼容阿里云百炼 / DashScope 的 OpenAI-compatible 接口
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3-vl-flash
VISION_MAX_INLINE_BYTES=7340032

# 豆包
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=

# 302AI
_302AI_API_KEY=

# ─── 微信机器人（可选）──────────────────────────────────────────────────────
WECHAT_ENABLED=false
WECHAT_PUPPET=wechaty-puppet-wechat4u
WECHAT_BOT_NAME=Girlfriend
# 默认保存在本机运行数据目录，不建议放到 Google Drive 同步目录
WECHAT_SESSION_DIR=
WECHAT_AUTO_BIND_SINGLE_READY_PERSONA=true

# ─── QQ / OneBot（可选，推荐配合 NapCatQQ）──────────────────────────────────
QQ_ENABLED=false
QQ_ONEBOT_BASE_URL=http://127.0.0.1:3001
QQ_ONEBOT_ACCESS_TOKEN=
QQ_ONEBOT_WEBHOOK_SECRET=
QQ_ALLOW_GROUPS=false
QQ_AUTO_BIND_SINGLE_READY_PERSONA=true

# ─── 其他 ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
PYTHON_PATH=python3
SKILL_ENGINE_DIR=./skill-engine
PORT=3000
